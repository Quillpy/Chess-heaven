# Database
# Use a MongoDB Atlas connection string for deployment.
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/chess-heaven?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/chess-heaven

# Clerk Authentication
# Get these from your Clerk Dashboard (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# App Configuration
# For local development, leave these as http://localhost:3000
# For Railway/Vercel, set these to your assigned domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
