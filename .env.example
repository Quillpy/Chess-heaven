# Database
# Use a MongoDB Atlas connection string for deployment on Railway.
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/chess-heaven?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/chess-heaven

# Clerk Authentication
# Get these from your Clerk Dashboard (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# App Configuration
# Mode: local | deploy
APP_MODE=local

# Local Development URL
NEXT_PUBLIC_LOCAL_URL=http://localhost:3000

# Deployment URLs (Used when APP_MODE=deploy)
# FRONTEND_URL: Your Vercel domain (e.g., https://chess-heaven.vercel.app)
# BACKEND_URL: Your Railway/Backend domain (If different from frontend)
NEXT_PUBLIC_DEPLOY_FRONTEND_URL=https://your-vercel-app.vercel.app
NEXT_PUBLIC_DEPLOY_BACKEND_URL=https://your-railway-app.railway.app
