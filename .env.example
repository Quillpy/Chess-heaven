# Supabase (Database)
# Get these from Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Clerk (Authentication)
# Get these from your Clerk Dashboard -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Deployment Configuration
# Set APP_MODE to 'deploy' when deploying to Vercel/Railway
APP_MODE=local
NEXT_PUBLIC_LOCAL_URL=http://localhost:3000

# Required for 'deploy' mode
NEXT_PUBLIC_DEPLOY_FRONTEND_URL=https://your-app.vercel.app
NEXT_PUBLIC_DEPLOY_BACKEND_URL=https://your-app.vercel.app
